PORT=3001
NODE_ENV=test

# Test Database (use same as dev for now, or separate test DB)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# JWT Test Keys (same as dev for tests)
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""
JWT_ACCESS_EXPIRES="15m"

# CORS for tests
ALLOWED_ORIGINS="http://localhost:3001"

# Cloudinary test (optional)
CLOUD_NAME="test"
API_KEY="test"
API_SECRET="test"

# Logging in tests
LOG_LEVEL="error"
