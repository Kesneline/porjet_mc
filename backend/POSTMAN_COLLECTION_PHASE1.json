    {
      "name": "3. Register - Valid User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"valid@test.com\",\n  \"password\": \"Password123\",\n  \"name\": \"Valid User Name\",\n  \"university\": \"Test University\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        },
        "description": "Register a valid user"
      },
      "response": []
    },
    {
      "name": "4. Register - XSS Attempt in Name",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"xss1@test.com\",\n  \"password\": \"Password123\",\n  \"name\": \"<script>alert('xss')</script>\",\n  \"university\": \"Test Uni\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        },
        "description": "EXPECTED: Script tag should be sanitized/escaped in response and DB"
      },
      "response": []
    },
    {
      "name": "4. Register - XSS Attempt in University",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"xss2@test.com\",\n  \"password\": \"Password123\",\n  \"name\": \"Test User\",\n  \"university\": \"<img src=x onerror=alert('xss')>\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        },
        "description": "EXPECTED: IMG tag should be sanitized/escaped"
      },
      "response": []
    },
