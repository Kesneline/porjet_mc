    {
      "name": "6. CORS Test - Blocked Origin",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Origin",
            "value": "https://evil-site.com"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/listings",
          "host": ["{{baseUrl}}"],
          "path": ["api", "listings"]
        },
        "description": "EXPECTED: CORS error or no Access-Control-Allow-Origin header"
      },
      "response": []
    },
    {
      "name": "6. CORS Test - Allowed Origin",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Origin",
            "value": "http://localhost:3000"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/listings",
          "host": ["{{baseUrl}}"],
          "path": ["api", "listings"]
        },
        "description": "EXPECTED: Success with Access-Control-Allow-Origin header"
      },
      "response": []
