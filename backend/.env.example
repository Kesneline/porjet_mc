PORT=3000
NODE_ENV=development

# URL Prisma avec PgBouncer (Port 6543)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL directe (Port 5432)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# JWT Secrets (laisser vide localement ou mettre clés de test)
# En production, générer avec: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""
JWT_ACCESS_EXPIRES="15m"

# CORS - Origines autorisées (séparées par des virgules)
# Développement : localhost:3000,localhost:8080,localhost:5000
# Production : https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8080,http://localhost:5000"

# Cloudinary - Cloud media storage
CLOUD_NAME="your_cloudinary_name"
API_KEY="your_cloudinary_api_key"
API_SECRET="your_cloudinary_api_secret"

# Logging level (development: debug, production: warn)
LOG_LEVEL="debug"

# Algolia (optionnel)
ALGOLIA_APP_ID="LC1CSCMQEQ"
ALGOLIA_WRITE_API_KEY=""
SEARCHABLE_API_KEY="78d93db739109c20da5a5edc2c4435d0"

RESEND_API_KEY=re_123456789  # Get from https://resend.com